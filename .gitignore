# ============================================================
# Bookcheck — .gitignore
# ============================================================

# --- SECURITY: Environment & Secrets (NEVER COMMIT) ---
.env
*.env
!.env.example

# --- Miscellaneous ---
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# --- IntelliJ related ---
*.iml
*.ipr
*.iws
.idea/

# --- VS Code (optional, uncomment if you don't want to share launch config) ---
# .vscode/

# --- Flutter/Dart/Pub related ---
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# --- Symbolication related ---
app.*.symbols

# --- Obfuscation related ---
app.*.map.json

# --- Android Studio build artifacts ---
/android/app/debug
/android/app/profile
/android/app/release

# --- NOTE: google-services.json is intentionally NOT ignored ---
# Firebase designed this file to be safe for version control.
# It does not contain secret keys — only project identifiers.
# See: https://firebase.google.com/docs/projects/learn-more#config-files-objects
