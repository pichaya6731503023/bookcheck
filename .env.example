# ============================================================
# Bookcheck — Firebase Configuration Template
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your Firebase values from:
#    https://console.firebase.google.com → Project Settings
# 3. Run: flutter run --dart-define-from-file=.env
# ============================================================

# --- Android ---
ANDROID_API_KEY=your_android_api_key_here
ANDROID_APP_ID=your_android_app_id_here

# --- Web ---
WEB_API_KEY=your_web_api_key_here
WEB_APP_ID=your_web_app_id_here
WEB_AUTH_DOMAIN=your-project.firebaseapp.com
WEB_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Shared ---
MESSAGING_SENDER_ID=your_sender_id_here
PROJECT_ID=your-firebase-project-id
STORAGE_BUCKET=your-project.firebasestorage.app
